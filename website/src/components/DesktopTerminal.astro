---
import TerminalPrompt from "./TerminalPrompt.astro";
import TerminalCommand from "./TerminalCommand.astro";
import FastfetchOutput from "./outputs/FastfetchOutput.astro";
import WhoamiOutput from "./outputs/WhoamiOutput.astro";
import ProjectsOutput from "./outputs/ProjectsOutput.astro";
import { TERMINAL_CONFIG } from "../lib/constants";

// Ordered list of terminal "states". Scrolling steps forward/backward through
// these; each renders a typed command followed by its output. Adding a new
// command is a one-line entry here (plus its Output component) — the controller
// below is fully generic over this array.
const states = [
    { key: "fastfetch", command: "fastfetch", Output: FastfetchOutput, startDelay: 0 },
    { key: "whoami", command: "whoami", Output: WhoamiOutput, startDelay: 500 },
    { key: "projects", command: "ls projects/", Output: ProjectsOutput, startDelay: 500 },
];
---

<!--
    Snap Scroll Container
    - h-screen & overflow-y-scroll: Creates a scrollable area within the viewport.
    - snap-y & snap-mandatory: Enforces snapping to child elements.
-->
<div
    class="h-screen w-full overflow-y-scroll snap-y snap-mandatory relative scroll-smooth"
    id="desktop-scroll-container"
>
    <!--
        Sticky Visual Layer
        Using sticky + negative margin ensures scroll events bubble correctly within the container
        instead of escaping to the body (which has overflow:hidden).
    -->
    <div
        class="sticky top-0 h-screen w-full z-20 flex flex-col pt-12 pointer-events-none p-8"
    >
        <div
            id="terminal-content"
            class="font-mono text-base md:text-base lg:text-lg xl:text-xl leading-tight w-fit pointer-events-auto"
        >
            {
                states.map((state, index) => {
                    const Output = state.Output;
                    return (
                        <div
                            id={`state-${state.key}`}
                            class={`terminal-state transition-opacity duration-300 ${index !== 0 ? "hidden" : ""}`}
                        >
                            <div class="mb-4">
                                <TerminalPrompt
                                    user={TERMINAL_CONFIG.user}
                                    host={TERMINAL_CONFIG.host}
                                >
                                    <TerminalCommand
                                        command={state.command}
                                        id={`cmd-${state.key}`}
                                        triggerEventName={`trigger-${state.key}`}
                                        onCompleteEventName={`complete-${state.key}`}
                                        startDelay={state.startDelay}
                                    />
                                </TerminalPrompt>
                            </div>
                            <div
                                id={`output-${state.key}`}
                                class="output-container hidden fade-in"
                            >
                                <Output />
                            </div>

                            {/* Trailing "clear" prompt — typed when leaving this state (either direction). */}
                            <div
                                id={`clear-${state.key}`}
                                class="interaction-layer mt-2 py-1 hidden"
                            >
                                <TerminalPrompt
                                    user={TERMINAL_CONFIG.user}
                                    host={TERMINAL_CONFIG.host}
                                >
                                    <TerminalCommand
                                        command="clear"
                                        id={`cmd-clear-${state.key}`}
                                        triggerEventName={`trigger-clear-${state.key}`}
                                        onCompleteEventName={`complete-clear-${state.key}`}
                                        typingSpeed={50}
                                    />
                                </TerminalPrompt>
                            </div>
                        </div>
                    );
                })
            }
        </div>
    </div>

    <!-- Scroll Track (Ghost Sections for Snapping) -->
    <div class="relative z-10 w-full -mt-[100vh]">
        {
            states.map((state, index) => (
                <section
                    class="h-screen w-full snap-start"
                    data-state={state.key}
                    data-index={index}
                />
            ))
        }
    </div>

    <!-- Scroll Indicator -->
    <div
        id="scroll-indicator"
        class="fixed bottom-12 left-1/2 -translate-x-1/2 z-50 transition-opacity duration-300 pointer-events-none hidden"
    >
        <div
            class="flex flex-col items-center gap-2 animate-bounce text-ctp-peach drop-shadow-md"
        >
            <div class="flex flex-col items-center">
                <span class="text-xs font-bold font-mono tracking-widest mb-1"
                    >SCROLL OR PRESS</span
                >
                <div class="flex gap-2 text-xl">
                    <i class="nf nf-fa-angle_up"></i>
                    <i class="nf nf-fa-angle_down"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Catppuccin Scrollbar */
    #desktop-scroll-container {
        scrollbar-width: thin;
        scrollbar-color: var(--color-ctp-surface0) transparent;
    }

    #desktop-scroll-container::-webkit-scrollbar {
        width: 6px;
    }

    #desktop-scroll-container::-webkit-scrollbar-track {
        background: transparent;
    }

    #desktop-scroll-container::-webkit-scrollbar-thumb {
        background-color: var(--color-ctp-surface0);
        border-radius: 9999px;
    }

    #desktop-scroll-container::-webkit-scrollbar-thumb:hover {
        background-color: var(--color-ctp-surface1);
    }
</style>

<script define:vars={{ stateKeys: states.map((s) => s.key) }}>
    const lastIndex = stateKeys.length - 1;

    // Controller state
    let currentIndex = 0;
    let isAnimating = false;
    let pendingTarget = 0;

    const scrollIndicator = document.getElementById("scroll-indicator");

    // Element lookups
    const stateEl = (k) => document.getElementById(`state-${k}`);
    const outputEl = (k) => document.getElementById(`output-${k}`);
    const clearEl = (k) => document.getElementById(`clear-${k}`);

    // Reset a "clear" prompt back to its empty, cursor-visible waiting state.
    function resetClear(k) {
        const text = document.getElementById(`cmd-clear-${k}-text`);
        if (text) text.textContent = "";
        const cursor = document.getElementById(`cmd-clear-${k}-cursor`);
        if (cursor) cursor.style.display = "inline-block";
    }

    function updateIndicator() {
        if (!scrollIndicator) return;
        // Reveal on first paint; hide once there's nothing below to scroll to.
        scrollIndicator.classList.remove("hidden");
        if (currentIndex >= lastIndex) {
            scrollIndicator.classList.add("opacity-0");
        } else {
            scrollIndicator.classList.remove("opacity-0");
        }
    }

    // Kick off the first command.
    setTimeout(() => {
        window.dispatchEvent(new Event(`trigger-${stateKeys[0]}`));
    }, 100);

    // Per-state handlers: command completion + clear completion.
    stateKeys.forEach((k, idx) => {
        // Command finished typing -> reveal output, park a waiting "clear" prompt.
        window.addEventListener(`complete-${k}`, () => {
            const out = outputEl(k);
            if (out) out.classList.remove("hidden");

            const cmdCursor = document.getElementById(`cmd-${k}-cursor`);
            if (cmdCursor) cmdCursor.style.display = "none";

            const clear = clearEl(k);
            if (clear) {
                clear.classList.remove("hidden");
                resetClear(k);
            }

            currentIndex = idx;
            isAnimating = false;
            updateIndicator();
        });

        // "clear" finished typing -> swap to the pending target and type its command.
        window.addEventListener(`complete-clear-${k}`, () => {
            const targetKey = stateKeys[pendingTarget];

            // Hide the current state entirely (its output + clear go with it).
            const current = stateEl(k);
            if (current) current.classList.add("hidden");

            // Reveal the target fresh and re-run its typing animation.
            const target = stateEl(targetKey);
            if (target) target.classList.remove("hidden");
            const targetOut = outputEl(targetKey);
            if (targetOut) targetOut.classList.add("hidden");
            const targetClear = clearEl(targetKey);
            if (targetClear) targetClear.classList.add("hidden");

            window.dispatchEvent(new Event(`trigger-${targetKey}`));
        });
    });

    // Begin a transition from the current state to a target index.
    function startTransition(targetIndex) {
        if (isAnimating || targetIndex === currentIndex) return;
        isAnimating = true;
        pendingTarget = targetIndex;

        const k = stateKeys[currentIndex];
        const clear = clearEl(k);
        if (clear) {
            clear.classList.remove("hidden");
            resetClear(k);
            window.dispatchEvent(new Event(`trigger-clear-${k}`));
        }
    }

    // Scroll snapping drives transitions.
    const observer = new IntersectionObserver(
        (entries) => {
            entries.forEach((entry) => {
                if (entry.isIntersecting && !isAnimating) {
                    const targetIndex = Number(entry.target.dataset.index);
                    if (targetIndex !== currentIndex) {
                        startTransition(targetIndex);
                    }
                }
            });
        },
        {
            root: document.getElementById("desktop-scroll-container"),
            threshold: 0.5,
        },
    );

    document.querySelectorAll("section[data-state]").forEach((section) => {
        observer.observe(section);
    });

    // Keyboard navigation (Up/Down steps between sections).
    window.addEventListener("keydown", (e) => {
        const container = document.getElementById("desktop-scroll-container");
        if (!container || container.offsetParent === null) return;

        if (e.key === "ArrowDown" || e.key === "ArrowUp") {
            e.preventDefault();

            const height = container.clientHeight;
            const currentScroll = container.scrollTop;
            const totalSections = document.querySelectorAll(
                "section[data-state]",
            ).length;

            const scrollIndex = Math.round(currentScroll / height);
            let targetIndex = scrollIndex;

            if (e.key === "ArrowDown") targetIndex = scrollIndex + 1;
            else if (e.key === "ArrowUp") targetIndex = scrollIndex - 1;

            if (targetIndex < 0) targetIndex = 0;
            if (targetIndex >= totalSections) targetIndex = totalSections - 1;

            if (targetIndex !== scrollIndex) {
                container.scrollTo({
                    top: targetIndex * height,
                    behavior: "smooth",
                });
            }
        }
    });
</script>
