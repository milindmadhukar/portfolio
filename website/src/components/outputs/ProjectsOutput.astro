---
import { projects } from "../../lib/constants";
---

<div class="fade-in max-w-4xl text-ctp-text leading-snug font-mono">
    <div class="text-ctp-subtext0 mb-2">total {projects.length}</div>

    <div class="flex flex-col gap-1">
        {
            projects.map((p) => (
                <details class="project group rounded">
                    {/* Collapsed row: just the project name + a hint of the description */}
                    <summary class="summary flex flex-wrap items-baseline gap-x-3 px-2 py-1.5 -ml-2 rounded cursor-pointer select-none">
                        <span class="chevron text-ctp-overlay1 inline-block transition-transform duration-200">
                            <i class="nf nf-fa-angle_right" />
                        </span>
                        <span class="text-ctp-blue font-bold group-hover:text-ctp-teal transition-colors">
                            {p.id}/
                        </span>
                        <span class="hint text-ctp-subtext0 truncate">
                            {p.description}
                        </span>
                    </summary>

                    {/* Expanded details: description, tech tags, then GitHub link */}
                    <div class="pl-8 pr-2 pb-2 pt-1 flex flex-col gap-1">
                        <div class="text-ctp-text">{p.description}</div>
                        <div class="text-ctp-subtext0">
                            <span class="text-ctp-overlay1">├─</span>{" "}
                            {p.technologies.join(" · ")}
                        </div>
                        <div>
                            <span class="text-ctp-overlay1">└─</span>{" "}
                            {p.links.github ? (
                                <a
                                    href={p.links.github}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="text-ctp-teal hover:underline"
                                >
                                    <i class="nf nf-fa-github" />{" "}
                                    {p.links.github.replace(/^https?:\/\//, "")}
                                </a>
                            ) : (
                                <span class="text-ctp-subtext0">source private</span>
                            )}
                        </div>
                    </div>
                </details>
            ))
        }
    </div>
</div>

<style>
    /* Kill the default disclosure triangle across browsers */
    .summary {
        list-style: none;
        transition:
            background-color 0.2s ease,
            box-shadow 0.2s ease;
    }
    .summary::-webkit-details-marker {
        display: none;
    }

    /* Hover glow — a subtle blue lift on the whole row */
    .summary:hover {
        background-color: rgba(137, 180, 250, 0.06);
        box-shadow: 0 0 8px rgba(137, 180, 250, 0.25);
    }

    /* Rotate the chevron and fade the inline hint away once expanded */
    .project[open] > .summary .chevron {
        transform: rotate(90deg);
    }
    .project[open] > .summary .hint {
        display: none;
    }

    /* One-shot glow flash when a row opens, settling into a faint tint */
    .project[open] > .summary {
        animation: project-open-glow 0.9s ease-out forwards;
    }

    @media (prefers-reduced-motion: reduce) {
        .summary,
        .chevron {
            transition: none;
        }
        .project[open] > .summary {
            animation: none;
            background-color: rgba(137, 180, 250, 0.06);
        }
    }
</style>
